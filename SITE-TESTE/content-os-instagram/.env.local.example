# Copy this file to .env.local and fill in your keys
# Keys are also saved in-app via Settings → APIs

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_KEY=your-supabase-anon-key

