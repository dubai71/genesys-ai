# ============================================
# API KEYS - NurseLab v4
# ============================================
# Todas as chaves são opcionais e podem ser configuradas na interface (APIs).
# Variáveis de ambiente servem como fallback para uso em servidor.
# Use as chaves de ambiente para evitar digitação repetida; a interface salva em localStorage.

# --- Text AI Providers ---
# OpenAI (GPT-4o, GPT-4 Turbo) - pago, trial gratuito USD 5
#OPENAI_API_KEY=sk-proj-...
# DeepSeek (V3, Chat) - muito barato, alta qualidade
#DEEPSEEK_API_KEY=sk-...
# Groq (Llama 3, Mixtral) - gratuito 100 req/dia, ultra-rápido
#GROQ_API_KEY=gsk_...
# Together AI (Llama 3, Mixtral) - USD 25 créditos grátis
#TOGETHER_API_KEY=...
# HuggingFace Inference API - free tier limitado
#HUGGINGFACE_API_KEY=hf_...

# --- Image AI Providers ---
# fal.ai (Flux, SDXL) - free tier limitado
#FALAI_API_KEY=...
# OpenAI DALL-E 3/2 - pago, trial USD 5
# (OpenAI já configurado acima)
# Replicate (SD3, FLUX, etc.) - free tier limitado, pós-gratuito
#REPLICATE_API_TOKEN=r8_...
# Stability AI (SDXL Turbo) - free tier limitado
#STABILITY_API_KEY=...
# Google Gemini Imagen 2 - usar mesma GEMINI_API_KEY
# (Gemini já configurado abaixo)
# Ideogram - free tier disponível
#IDEOGRAM_API_KEY=...
# Leonardo AI - free tier daily tokens
#LEONARDO_API_KEY=...

# --- Video AI Providers ---
# Higgsfield Seedance - free trial
#HIGGSFIELD_API_KEY=...
# Replicate video models (ZeroScope, SVD) - free tier
# (Replicate já configurado acima)
# Pika Labs - free tier disponível
#PIKA_API_KEY=...
# Runway ML - trial gratuito
#RUNWAY_API_KEY=...
# Kling AI - gratuito
#KLING_API_KEY=...
# Haiper - free tier
#HAIPER_API_KEY=...
# Luma Dream Machine - free limited
#LUMA_API_KEY=...
# HuggingFace video models - free tier
# (HuggingFace já configurado acima)

# --- Stock Media & Utilities ---
# Unsplash API - free 50 req/hora
#UNSPLASH_ACCESS_KEY=...
# Pexels API - free 200 req/hora
#PEXELS_API_KEY=...
# Remove.bg (ou Pixelcut) - free tier 50 req/mês
#REMOVE_BG_API_KEY=...
# Pixelcut (backup) - free tier
#PIXELCUT_API_KEY=...

# --- Existing Providers ---
# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=sua_url_aqui
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_publica_aqui
# Service role key (apenas servidor) - necessária para upload de arquivos
SUPABASE_SERVICE_ROLE_KEY=sua_chave_secreta_service_role_aqui

# Google Gemini - opcional (configurável também na interface)
#GEMINI_API_KEY=AIza...
# Perplexity - opcional (configurável também na interface)
#PERPLEXITY_API_KEY=...
# Perplexica local - opcional. Tambem pode ser configurado na interface em APIs.
# Use a URL base ou a rota completa /api/search.
#PERPLEXICA_API_URL=http://127.0.0.1:3001
# Opcional: fixe os modelos se nao quiser autodetectar via /api/providers.
#PERPLEXICA_CHAT_PROVIDER_ID=
#PERPLEXICA_CHAT_MODEL=
#PERPLEXICA_EMBEDDING_PROVIDER_ID=
#PERPLEXICA_EMBEDDING_MODEL=
# Freepik - opcional
#FREEPIK_API_KEY=...
# Segmind - opcional (configurável também na interface)
#SEGMIND_API_URL=https://api.segmind.com/v1
#SEGMIND_API_KEY=...

# ============================================
# NOTA: Todas as chaves acima também podem ser configuradas na interface
# através do módulo "APIs" (ícone-chave na sidebar).
# O sistema prioriza as chaves configuradas na interface sobre estas variáveis de ambiente.
# ============================================
